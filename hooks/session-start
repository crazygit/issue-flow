#!/usr/bin/env bash
# SessionStart hook for issue-flow plugin
# Reads the issue-flow SKILL.md and injects a summary as session context.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read issue-flow skill content
issue_flow_content=$(cat "${PLUGIN_ROOT}/skills/issue-flow/SKILL.md" 2>&1 || echo "Error reading issue-flow skill")

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

issue_flow_escaped=$(escape_for_json "$issue_flow_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have issue-flow.\n\n**Below is the full content of your 'issue-flow' skill — an issue-driven development orchestrator. Requires superpowers as a runtime dependency.**\n\n${issue_flow_escaped}\n\n<important-reminder>Before starting issue-flow, verify the required superpowers skills are discoverable. Claude Code install command: /plugin install superpowers@claude-plugins-official . Codex install path: enable Superpowers from OpenAI Curated, then run bash scripts/install-codex.sh from the issue-flow repo and install issue-flow from Personal Plugins.</important-reminder>\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code and Codex expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI expects additionalContext (top-level).
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${COPILOT_CLI:-}" ]; then
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
else
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
fi

exit 0
