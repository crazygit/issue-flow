#!/usr/bin/env bash
# state-transition-guard.sh
# PreToolUse hook for Claude Code that validates issue-flow and bugfix-flow
# skill state transitions.
#
# Receives JSON on stdin from Claude Code hooks.
# - Reads the skill name from tool_input
# - Checks .issue-flow/state for current state
# - Blocks illegal transitions (exit 2 with JSON error)
# - Passes legal transitions (exit 0, no output)

set -euo pipefail

# --- Read stdin JSON ---
INPUT=$(cat)

# Extract skill name from tool_input.name (jq)
SKILL_NAME=$(echo "$INPUT" | jq -r '.tool_input.name // empty' 2>/dev/null)

# If not a workflow skill, pass through
if [[ -z "$SKILL_NAME" ]] || [[ "$SKILL_NAME" != issue-* && "$SKILL_NAME" != bugfix-* ]]; then
  exit 0
fi

# --- Resolve state file by workflow prefix ---
STATE_DIR_NAME=".issue-flow"
if [[ "$SKILL_NAME" == bugfix-* ]]; then
  STATE_DIR_NAME=".bugfix-flow"
fi

find_state_file() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/${STATE_DIR_NAME}/state" ]]; then
      echo "$dir/${STATE_DIR_NAME}/state"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}

STATE_FILE=""
CURRENT_STATE="none"

if find_state_file > /dev/null 2>&1; then
  STATE_FILE=$(find_state_file)
  STATE_VALUE=$(cat "$STATE_FILE" 2>/dev/null | tr -d '[:space:]')
  if [[ -n "$STATE_VALUE" ]]; then
    CURRENT_STATE="$STATE_VALUE"
  else
    CURRENT_STATE="none"
  fi
else
  CURRENT_STATE="none"
  # No state file exists; only certain skills are allowed
  # Special case: finish skills should be allowed even without state file
  # (state may have been deleted during cleanup)
  if [[ "$SKILL_NAME" == "issue-finish" || "$SKILL_NAME" == "bugfix-finish" ]]; then
    exit 0
  fi
fi

# --- Define legal transitions: skill -> required current states ---
# Each skill maps to an array of states from which it can be called.
declare -A TRANSITIONS

# issue-flow transitions
TRANSITIONS[issue-brainstorm]="none"
TRANSITIONS[issue-create]="none"
TRANSITIONS[issue-pick]="none"
TRANSITIONS[issue-plan]="researching"
TRANSITIONS[issue-research]="picked"
TRANSITIONS[issue-implement]="planned reviewing"
TRANSITIONS[issue-verify]="implementing reviewing"
TRANSITIONS[issue-commit]="committing"
TRANSITIONS[issue-pr]="pring"
TRANSITIONS[issue-finish]="finished"

# bugfix-flow transitions
TRANSITIONS[bugfix-pick]="none"
TRANSITIONS[bugfix-implement]="picked ready"
TRANSITIONS[bugfix-verify]="implementing"
TRANSITIONS[bugfix-finish]="finished"

# --- Validate transition ---
ALLOWED_STATES="${TRANSITIONS[$SKILL_NAME]:-}"

if [[ -z "$ALLOWED_STATES" ]]; then
  # Unknown workflow skill — allow it (don't block unlisted skills)
  exit 0
fi

# Check if current state is in the allowed list
IS_LEGAL=false
for state in $ALLOWED_STATES; do
  if [[ "$CURRENT_STATE" == "$state" ]]; then
    IS_LEGAL=true
    break
  fi
done

if [[ "$IS_LEGAL" == true ]]; then
  # Legal transition — allow
  exit 0
else
  # Illegal transition — block
  # Format allowed states as a human-readable list
  FORMATTED_ALLOWED=$(echo "$ALLOWED_STATES" | sed 's/ / or /g')
  cat <<EOF
{"decision": "block", "reason": "Invalid state transition: cannot call ${SKILL_NAME} from state '${CURRENT_STATE}'. Current state must be ${FORMATTED_ALLOWED}."}
EOF
  exit 2
fi
