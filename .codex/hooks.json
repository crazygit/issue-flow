{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/hooks/run-hook.cmd\" session-start",
            "statusMessage": "Loading issue-flow workspace context"
          }
        ]
      }
    ]
  }
}
